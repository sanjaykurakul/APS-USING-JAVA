Question 9 - Strassen Matrix (2×2)
import java.util.*;

public class StrassenMatrix {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a11 = sc.nextInt();
        int a12 = sc.nextInt();
        int a21 = sc.nextInt();
        int a22 = sc.nextInt();

        // Strassen Multiplication A × A
        int m1 = (a11 + a22) * (a11 + a22);
        int m2 = (a21 + a22) * a11;
        int m3 = a11 * (a12 - a22);
        int m4 = a22 * (a21 - a11);
        int m5 = (a11 + a12) * a22;
        int m6 = (a21 - a11) * (a11 + a12);
        int m7 = (a12 - a22) * (a21 + a22);

        int c11 = m1 + m4 - m5 + m7;
        int c12 = m3 + m5;
        int c21 = m2 + m4;
        int c22 = m1 - m2 + m3 + m6;

        // Compute M = C - 9A
        int r11 = c11 - 9 * a11;
        int r12 = c12 - 9 * a12;
        int r21 = c21 - 9 * a21;
        int r22 = c22 - 9 * a22;

        System.out.println(r11 + " " + r12);
        System.out.println(r21 + " " + r22);

        sc.close();
    }
}
